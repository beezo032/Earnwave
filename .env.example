NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Production:
# CLIENT_URL=https://getearnwave.com
# PUBLIC_URL=https://getearnwave.com
PUBLIC_URL=http://localhost:5000

# Backend
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_NAME=EarnWave Admin

# PostgreSQL and Redis
DATABASE_URL=postgres://earnwave:earnwave@localhost:5432/earnwave
REDIS_URL=redis://localhost:6379

# Payments
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_ENV=sandbox

# Payout automation
TREMENDOUS_API_KEY=replace-me
TREMENDOUS_ENV=testflight
TREMENDOUS_FUNDING_SOURCE_ID=BALANCE
TREMENDOUS_PRODUCT_ID=OKMHM2X2OHYV

# Crypto withdrawals use Circle stablecoin payouts when configured.
CIRCLE_API_KEY=replace-me
CIRCLE_ENV=sandbox
CIRCLE_WALLET_ID=replace-me

# Offerwall postbacks
OFFERWALL_SHARED_SECRET=replace-me

# Real offerwall integrations
CPX_APP_ID=replace-me
CPX_API_KEY=replace-me
CPX_SECURE_HASH_SECRET=replace-me

ADGATE_WALL_URL=https://wall.adgaterewards.com/YOUR-WALL?user_id={userId}
ADGATE_POSTBACK_SECRET=replace-me

BITLABS_WALL_URL=https://web.bitlabs.ai/?uid={userId}
BITLABS_APP_SECRET=replace-me

LOOTABLY_WALL_URL=https://wall.lootably.com/?placementID=replace-me&userID={userId}
LOOTABLY_POSTBACK_SECRET=replace-me

TIMEWALL_WALL_URL=https://timewall.io/users/login?oid=replace-me&uid={userId}
TIMEWALL_POSTBACK_SECRET=replace-me

AYET_ADSLOT_ID=replace-me
AYET_API_KEY=replace-me
AYET_POSTBACK_SECRET=replace-me
