exports[`landing copy sections > matches the pending and reversal FAQ snapshot 1`] = `
<DocumentFragment>
  <section>
    <div
      class="container faq-wrap"
    >
      <div>
        <h2>
          Why rewards may pend or reverse
        </h2>
        <p>
          Clear rules reduce support tickets and help users understand reward timing before they start.
        </p>
      </div>
      <div
        class="faq-grid"
      >
        <article
          data-open="true"
        >
          <h3>
            Why do some rewards pend before becoming available?
          </h3>
          <p>
            Some providers confirm completions after a callback, quality check, or advertiser review. EarnWave shows pending rewards separately so users know what is still being verified.
          </p>
        </article>
        <article
          data-open="false"
        >
          <h3>
            Why can a reward reverse?
          </h3>
          <p>
            Rewards may reverse when a provider reports chargeback, duplicate account activity, VPN/proxy abuse, failed offer requirements, or advertiser rejection.
          </p>
        </article>
        <article
          data-open="false"
        >
          <h3>
            When can I cash out?
          </h3>
          <p>
            Available rewards can be withdrawn after the minimum cashout is met. Withdrawals enter review first for fraud protection.
          </p>
        </article>
        <article
          data-open="false"
        >
          <h3>
            Which payout methods are supported?
          </h3>
          <p>
            EarnWave is built for PayPal Payouts, Tremendous gift cards, crypto withdrawals, and manual approval before automation runs.
          </p>
        </article>
      </div>
    </div>
  </section>
</DocumentFragment>
`;

exports[`landing copy sections > matches the pending versus available explainer snapshot 1`] = `
<DocumentFragment>
  <section
    class="split-section"
  >
    <div
      class="container split-grid"
    >
      <div>
        <div>
          <h2>
            Pending vs available rewards
          </h2>
          <p>
            EarnWave separates reward status so users understand what can be withdrawn and what is still being verified.
          </p>
        </div>
        <div
          class="security-list"
        >
          <div
            class="security-row status-explainer-row"
          >
            <svg
              class="lucide lucide-circle-check-big"
              fill="none"
              height="18"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="18"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M21.801 10A10 10 0 1 1 17 3.335"
              />
              <path
                d="m9 11 3 3L22 4"
              />
            </svg>
            <span>
              <strong>
                Available rewards
              </strong>
              Cleared rewards already credited to your balance and eligible for withdrawal once you meet the minimum cashout.
            </span>
          </div>
          <div
            class="security-row status-explainer-row"
          >
            <svg
              class="lucide lucide-circle-check-big"
              fill="none"
              height="18"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="18"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M21.801 10A10 10 0 1 1 17 3.335"
              />
              <path
                d="m9 11 3 3L22 4"
              />
            </svg>
            <span>
              <strong>
                Pending rewards
              </strong>
              Tracked rewards waiting on provider callback, hold period, duplicate checks, or manual fraud review.
            </span>
          </div>
        </div>
      </div>
      <div
        class="card security-panel"
      >
        <div
          class="risk-score"
        >
          <span>
            Reward status
          </span>
          <strong>
            Clear
          </strong>
        </div>
        <div
          class="row"
        >
          <span>
            Available balance
          </span>
          <span
            class="pill"
          >
            $48.75
          </span>
        </div>
        <div
          class="row"
        >
          <span>
            Pending verification
          </span>
          <span
            class="pill blue"
          >
            $12.40
          </span>
        </div>
        <div
          class="row"
        >
          <span>
            Manual payout review
          </span>
          <span
            class="pill"
          >
            Required
          </span>
        </div>
      </div>
    </div>
  </section>
</DocumentFragment>
`;

