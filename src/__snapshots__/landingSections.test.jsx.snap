exports[`landing copy sections > matches the structured FAQ markup snapshot 1`] = `
<DocumentFragment>
  <script
    type="application/ld+json"
  >
    {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Why do some rewards pend before becoming available?","acceptedAnswer":{"@type":"Answer","text":"Some providers confirm completions after a callback, quality check, or advertiser review. EarnWave shows pending rewards separately so users know what is still being verified."}},{"@type":"Question","name":"Why can a reward reverse?","acceptedAnswer":{"@type":"Answer","text":"Rewards may reverse when a provider reports chargeback, duplicate account activity, VPN/proxy abuse, failed offer requirements, or advertiser rejection."}},{"@type":"Question","name":"When can I cash out?","acceptedAnswer":{"@type":"Answer","text":"Available rewards can be withdrawn after the minimum cashout is met. Withdrawals enter review first for fraud protection."}},{"@type":"Question","name":"Which payout methods are supported?","acceptedAnswer":{"@type":"Answer","text":"EarnWave is built for PayPal Payouts, Tremendous gift cards, crypto withdrawals, and manual approval before automation runs."}}]}
  </script>
</DocumentFragment>
`;

exports[`landing copy sections > matches the three-step how it works snapshot 1`] = `
<DocumentFragment>
  <section>
    <div
      class="container"
    >
      <div>
        <h2>
          How EarnWave works
        </h2>
        <p>
          A simple three-step flow from verified account to reviewed payout.
        </p>
      </div>
      <div
        class="process-grid three-step-grid"
      >
        <div
          class="card process-card"
        >
          <span
            class="rank"
          >
            1
          </span>
          <h3>
            Create a verified account
          </h3>
          <p>
            Sign up, confirm your email, and keep one account per person so rewards can be reviewed cleanly.
          </p>
        </div>
        <div
          class="card process-card"
        >
          <span
            class="rank"
          >
            2
          </span>
          <h3>
            Choose an earning method
          </h3>
          <p>
            Start with surveys, offerwalls, games, daily streaks, referrals, or bonus codes from your dashboard.
          </p>
        </div>
        <div
          class="card process-card"
        >
          <span
            class="rank"
          >
            3
          </span>
          <h3>
            Track rewards to payout
          </h3>
          <p>
            Available rewards can be withdrawn; pending rewards wait for provider approval or fraud review.
          </p>
        </div>
      </div>
    </div>
  </section>
</DocumentFragment>
`;

